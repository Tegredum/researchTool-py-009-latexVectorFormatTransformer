{
  "name": "latexVectorFormatTransformer",
  "displayName": "009 LaTeX 矢量格式转换",
  "description": "将从 MathType 复制出的 LaTeX 公式格式进行处理，将正体变量批量处理为斜体",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "latexVectorFormatTransformer.convertDocument",
        "title": "转换 LaTeX 公式格式（当前文档）",
        "category": "LaTeX 格式转换"
      },
      {
        "command": "latexVectorFormatTransformer.convertAndPaste",
        "title": "转换并粘贴 LaTeX 公式（从剪贴板）",
        "category": "LaTeX 格式转换"
      }
    ],
    "configuration": {
      "title": "LaTeX 矢量格式转换",
      "properties": {
        "latexVectorFormatTransformer.pythonMode": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "direct", "conda"],
          "description": "Python 运行模式"
        },
        "latexVectorFormatTransformer.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python 解释器路径（直接模式）"
        },
        "latexVectorFormatTransformer.condaPath": {
          "type": "string",
          "default": "conda",
          "description": "conda 可执行文件路径（conda 模式）"
        },
        "latexVectorFormatTransformer.condaEnv": {
          "type": "string",
          "default": "",
          "description": "conda 环境名称，留空则用 base"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.106.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^9.32.0",
    "typescript": "^5.9.2",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
